# ── Database ───────────────────────────────────────────────────────────────
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_PORT=5432

# ── Backend ────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=5000

# REQUIRED — generate strong random strings for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_PORT=80

# The URL the browser uses to reach the backend API
# In production replace localhost with your domain/IP
REACT_APP_API_URL=http://localhost:5000/api

# Allowed CORS origin for the backend
CLIENT_ORIGIN=http://localhost:80
